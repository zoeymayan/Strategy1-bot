# =====================================================================
# Discretionary AVWAP Lock Service — environment variables
# Copy to .env on EC2 and fill in real values. Never commit .env.
# =====================================================================

# --- Dhan API (refreshed daily by refresh_token.py cron) ---
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=
DHAN_PIN=              # 6-digit Dhan login PIN (used by refresh_token.py)
DHAN_TOTP_SECRET=      # Base32 secret from Dhan Web -> DhanHQ APIs -> Enable TOTP

# --- Telegram (dedicated bot for this service) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Service config ---
WEBHOOK_SECRET=        # random string; set same value in all 4 TV alert messages
TRADE_QTY=1            # lots per trade (1 lot = 65 qty). Change here + systemctl restart discretionary
POLL_INTERVAL=30       # seconds between position polls
ENTRY_COOLDOWN=60      # seconds after an entry before another entry is allowed
FLASK_PORT=5001
